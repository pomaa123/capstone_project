<%- include('partials/header.ejs') %>



<div class="container py-4"> 
        <h1 class="title">Sign Up to Our Service</h1>
        <p class="text-body-secondary title">Fill this form to sign up to our service</p>

        <form class="needs-validation" novalidate="" action="/signup" method="POST">
            <hr> 
            <div class="row g-3"> 
                <div><label>Name</label></div>
                <div class="col-sm-6"> 
                    <!-- <label for="firstName" class="form-label">Name</label>  -->
                    <input type="text" class="form-control" id="firstName" placeholder="" value="" required=""> 
                    <small class="text-body-secondary">first name</small>
                    <div class="invalid-feedback">Valid first name is required.</div> 
                </div> 
                <div class="col-sm-6"> 
                    <input type="text" class="form-control" id="lastName" placeholder="" value="" required=""> 
                    <small class="text-body-secondary">last name </small>
                    <div class="invalid-feedback">Valid last name is required.</div> 
                </div> 
                
                <div class="col-12"> <label for="username" class="form-label">Username</label> 
                    <div class="input-group has-validation"> <span class="input-group-text">@</span> <input type="text" class="form-control" id="username" placeholder="Username" required="" name="username"> 
                        <div class="invalid-feedback">Your username is required.</div> 
                    </div> 
                </div> 
                <div class="col-12"> <label for="email" class="form-label">Email</label> 
                    <input type="email" class="form-control" id="email" placeholder="you@example.com" name="email"> 
                    <div class="invalid-feedback">Please enter a valid email address.</div> 
                </div> 
                <div class="col-12"> 
                    <label for="password" class="form-label">Password</label> 
                    <input type="text" class="form-control" id="password" name="password" required=""> 
                    <small class="text-body-secondary">minimum 8 entries </small>
                    <div class="invalid-feedback">Enter a vaild password.</div> 
                </div> 
                <div class="col-12"> 
                    <label for="password2" class="form-label">Re-enter password <span class="text-body-secondary">(Optional)</span></label> 
                    <input type="text" class="form-control" id="password2" >
                    <small class="text-body-secondary">re-enter the same password </small> 
                    <div class="invalid-feedback">password does not match.</div>
                </div>
            </div>    
            <p>May we send information about our product to the mailing address that you provided?</p>
            <div class="my-3"> 
                <div class="form-check"> 
                    <input id="yes-email" name="emailListing" type="radio" class="form-check-input" checked="" required=""> 
                    <label class="form-check-label" for="credit">Yes</label> 
                </div> 
                <div class="form-check"> 
                    <input id="no-email" name="emailListing" type="radio" class="form-check-input" required=""> 
                    <label class="form-check-label" for="debit">No</label> 
                </div> 
    
            </div>
            <hr class="my-4">
        <button class="w-100 btn btn-primary btn-lg" type="submit">Submit</button> 
    </form> 
</div> 

<%- include('partials/footer.ejs') %>
